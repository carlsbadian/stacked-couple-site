---
/**
 * Layout for pillar + optimization-category MDX pages under /the-stacks/.
 * Frontmatter schema is validated by the `stacks` collection in
 * src/content/config.ts (glob-loaded from the pages directory).
 */
import BaseLayout from './BaseLayout.astro';
import { SITE } from '../config/site';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    pillar: 'movement' | 'fuel' | 'optimization' | 'mind';
    eyebrow?: string;
    order?: number;
  };
}
const { frontmatter } = Astro.props;
const eyebrow = frontmatter.eyebrow ?? 'The Stacks';
---
<BaseLayout title={`${frontmatter.title} — ${SITE.name}`} description={frontmatter.description}>
  <section class="pillar-hero on-dark">
    <div class="wrap">
      <nav class="crumbs" aria-label="Breadcrumb">
        <a href="/the-stacks/">The Stacks</a>
        {frontmatter.eyebrow === 'Optimization' && (
          <><span aria-hidden="true">·</span><a href="/the-stacks/optimization/">Optimization</a></>
        )}
      </nav>
      <div class="label">{eyebrow}</div>
      <h1>{frontmatter.title}</h1>
      <p class="lede">{frontmatter.description}</p>
    </div>
  </section>
  <section>
    <div class="wrap prose">
      <slot />
    </div>
  </section>
</BaseLayout>

<style>
  .pillar-hero{padding:clamp(56px,8vw,90px) 0}
  .crumbs{margin-bottom:26px;font-family:var(--mono);font-size:12px;letter-spacing:0.1em}
  .crumbs a{color:var(--stone);text-decoration:none;text-transform:uppercase}
  .crumbs a:hover{color:var(--amber)}
  .crumbs span{margin:0 10px;color:var(--stone)}
  h1{margin:14px 0 18px}
  .lede{max-width:62ch;font-size:19px;color:rgba(250,247,242,0.78)}
</style>
