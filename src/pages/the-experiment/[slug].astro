---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';
import { SITE, LEGAL_FOOTER } from '../../config/site';

export async function getStaticPaths() {
  const posts = await getCollection('experiment', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

const pillarLabel: Record<string, string> = {
  movement: 'Movement',
  fuel: 'Fuel',
  optimization: 'Optimization',
  mind: 'Mind',
};
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC' });
---
<BaseLayout title={`${post.data.title} — ${SITE.name}`} description={post.data.description}>
  <article>
    <header class="article-hero on-dark">
      <div class="wrap">
        <nav class="crumbs" aria-label="Breadcrumb">
          <a href="/the-experiment/">The Experiment</a>
        </nav>
        <div class="meta">
          <a class="pillar" href={`/the-stacks/${post.data.pillar}/`}>
            {pillarLabel[post.data.pillar]}
          </a>
          <time datetime={post.data.pubDate.toISOString()}>{fmt(post.data.pubDate)}</time>
          {post.data.updated && (
            <span class="updated">Updated {fmt(post.data.updated)}</span>
          )}
        </div>
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
      </div>
    </header>
    <section>
      <div class="wrap prose">
        <Content />
        <hr />
        <p class="disclaimer">{LEGAL_FOOTER}</p>
      </div>
    </section>
  </article>
</BaseLayout>

<style>
  .article-hero{padding:clamp(56px,8vw,90px) 0}
  .crumbs{margin-bottom:26px;font-family:var(--mono);font-size:12px;letter-spacing:0.1em}
  .crumbs a{color:var(--stone);text-decoration:none;text-transform:uppercase}
  .crumbs a:hover{color:var(--amber)}
  .meta{display:flex;gap:20px;align-items:baseline;flex-wrap:wrap;margin-bottom:18px}
  .pillar{
    font-family:var(--mono);font-size:11px;letter-spacing:0.2em;
    text-transform:uppercase;color:var(--amber);text-decoration:none;
  }
  time,.updated{font-family:var(--mono);font-size:12px;color:var(--stone)}
  h1{max-width:22ch}
  .lede{max-width:60ch;font-size:19px;color:rgba(250,247,242,0.78);margin-top:16px}
  .disclaimer{font-size:13px;color:var(--stone)}
</style>
