---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { SITE } from '../../config/site';

const pillars = [
  {
    num: '01',
    name: 'Optimization',
    href: '/the-stacks/optimization/',
    tag: 'Data · Biohacking · Tracking',
    blurb: 'The data hub: peptide protocols, targeted supplements, tracking tech, and biomarker labs. We don’t guess, we test.',
  },
  {
    num: '02',
    name: 'Movement',
    href: '/the-stacks/movement/',
    tag: 'Training Life',
    blurb: 'Training frameworks, HIIT, weightlifting, and workout logs — the training life of two busy people making it happen.',
  },
  {
    num: '03',
    name: 'Fuel',
    href: '/the-stacks/fuel/',
    tag: 'Nutrition Frameworks',
    blurb: 'Foundational nutrition, dietary frameworks, macro targets, and meal profiles. Framework over daily detail.',
  },
  {
    num: '04',
    name: 'Mind',
    href: '/the-stacks/mind/',
    tag: 'Focus · Sleep · The Conversation',
    blurb: 'Focus, cognitive stacks, and sleep architecture — plus the honest midlife conversation that makes or breaks everything else.',
  },
];
---
<BaseLayout
  title={`The Stacks — ${SITE.name}`}
  description="The Stacks is the method: Optimization, Movement, Fuel, Mind. Four pillars — every post lives in exactly one."
>
  <section class="page-hero on-dark">
    <div class="wrap">
      <div class="label">The Stacks</div>
      <h1>Four pillars.<br />Every post lives in one.</h1>
      <p class="lede">
        Optimization · Movement · Fuel · Mind. The data and compounds behind it all,
        training and recovery, how we fuel, and the honest midlife conversation
        nobody else is having out loud.
      </p>
    </div>
  </section>

  <section class="lockup-sec">
    <div class="wrap lockup-grid">
      <img
        src="/brand/stacks-horizontal.webp"
        alt="Four pillar pennants in order: Optimization Stack, Movement Stack, Fuel Stack, Mind Stack."
        width="1100"
        height="415"
        loading="lazy"
      />
      <div class="lockup-copy">
        <div class="eyebrow-rule"><span class="label">The architecture</span></div>
        <p>
          The Stacks is the overarching concept — four pillars sit under it, and every
          post lives in exactly one. No orphan content, no vibes-only categories: if
          it doesn't fit a pillar, it doesn't ship.
        </p>
        <p class="muted">
          Pick a pillar below, or start with the ongoing log in
          <a href="/the-experiment/">The Experiment</a>.
        </p>
      </div>
    </div>
  </section>

  <section class="list-sec">
    <div class="wrap">
      <div class="pillar-list">
        {pillars.map((p) => (
          <a class="row" href={p.href}>
            <span class="num">{p.num}</span>
            <span class="name-tag">
              <span class="name">{p.name}</span>
              <span class="tag">{p.tag}</span>
            </span>
            <span class="blurb">{p.blurb}</span>
            <span class="go" aria-hidden="true">→</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-hero{padding:clamp(64px,9vw,110px) 0}
  .page-hero h1{margin:16px 0 18px}
  .lede{max-width:60ch;font-size:19px;color:rgba(250,247,242,0.78)}
  .lockup-sec{padding-bottom:0}
  .lockup-grid{
    display:grid;grid-template-columns:minmax(300px,520px) 1fr;
    gap:clamp(32px,5vw,72px);align-items:center;
  }
  @media(max-width:760px){.lockup-grid{grid-template-columns:1fr}}
  .lockup-grid img{display:block;width:100%;height:auto}
  .lockup-copy p{max-width:52ch;margin-bottom:1em;font-size:17px}
  .lockup-copy a{color:var(--copper)}
  .list-sec{padding-top:clamp(40px,6vw,64px)}
  .pillar-list{border-top:1px solid var(--line)}
  .row{
    display:grid;grid-template-columns:70px 240px 1fr 40px;gap:28px;align-items:center;
    padding:34px 4px;border-bottom:1px solid var(--line);text-decoration:none;
    transition:background .2s ease;
  }
  .row:hover{background:rgba(74,127,165,0.08)}
  .num{font-family:var(--mono);font-size:13px;color:var(--copper);letter-spacing:0.12em}
  .name{display:block;font-family:var(--serif);font-size:clamp(26px,3.4vw,36px);line-height:1.05}
  .tag{
    display:block;font-family:var(--mono);font-size:11px;letter-spacing:0.2em;
    text-transform:uppercase;color:var(--amber);margin-top:8px;
  }
  .blurb{font-size:15.5px;color:var(--navy);opacity:0.78}
  .go{color:var(--copper);font-size:22px}
  @media(max-width:820px){
    .row{grid-template-columns:1fr;gap:10px}
    .go{display:none}
  }
</style>
