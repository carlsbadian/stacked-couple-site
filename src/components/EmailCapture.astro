---
/**
 * Gated lead-magnet email capture — "Get the Guide".
 * The value proposition is execution and convenience: the printable
 * dosage tracker, reconstitution cheat sheet, and startup checklist.
 *
 * NOTE: no email provider is wired up yet. Submissions log to the
 * console as a placeholder. TODO(Todd): connect a provider (Substack /
 * ConvertKit / Mailchimp / Zoho) by setting `action` + hidden fields
 * per their embed docs — this component is the single place to do it.
 */
interface Props {
  heading?: string;
  compact?: boolean;
}
const {
  heading = 'The Peptide Guide We Wish We’d Had',
  compact = false,
} = Astro.props;
---
<div class:list={['capture', { compact }]}>
  <div class="label">Get the Guide</div>
  <h3>{heading}</h3>
  {!compact && (
    <p class="pitch">
      A straightforward breakdown of the compounds we use, what they do, and why we
      chose them. Yours when you join the list.
    </p>
  )}
  <form class="capture-form" novalidate>
    <label class="sr-only" for={`email-${compact ? 'c' : 'f'}`}>Email address</label>
    <input
      id={`email-${compact ? 'c' : 'f'}`}
      type="email"
      name="email"
      placeholder="you@example.com"
      autocomplete="email"
      required
    />
    <button type="submit" class="btn btn-solid">Get the Guide</button>
  </form>
  <p class="fine">
    By subscribing you agree to receive future emails from The Stacked Couple.
    We don’t spam. Unsubscribe anytime.
  </p>
</div>

<style>
  .capture{
    background:var(--navy);color:var(--cream);
    padding:clamp(32px,5vw,56px);border:1px solid var(--line-dark);
  }
  .capture .label{color:var(--amber);margin-bottom:14px}
  h3{margin-bottom:14px}
  .pitch{color:rgba(250,247,242,0.78);max-width:60ch;margin-bottom:26px}
  .compact .pitch{display:none}
  .capture-form{display:flex;gap:12px;flex-wrap:wrap;margin-bottom:14px}
  input[type='email']{
    flex:1;min-width:220px;padding:15px 18px;font-size:16px;
    font-family:var(--sans);border:1px solid var(--line-dark);
    background:rgba(250,247,242,0.06);color:var(--cream);
  }
  input[type='email']::placeholder{color:var(--stone)}
  input[type='email']:focus-visible{outline:3px solid var(--steel);outline-offset:2px}
  .fine{font-size:12.5px;color:rgba(250,247,242,0.55)}
  .sr-only{
    position:absolute;width:1px;height:1px;padding:0;margin:-1px;
    overflow:hidden;clip:rect(0 0 0 0);white-space:nowrap;border:0;
  }
</style>

<script>
  // Placeholder handler — replace with the email provider embed.
  document.querySelectorAll<HTMLFormElement>('.capture-form').forEach((form) => {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value;
      if (!email || !email.includes('@')) return;
      console.log('[email-capture placeholder] would subscribe:', email);
      const note = document.createElement('p');
      note.textContent = 'Almost live — the list opens soon. Check back shortly.';
      note.style.cssText = 'font-family:var(--mono);font-size:13px;color:var(--amber);margin-top:10px';
      form.after(note);
      form.querySelectorAll('input,button').forEach((el) => el.setAttribute('disabled', ''));
    });
  });
</script>
